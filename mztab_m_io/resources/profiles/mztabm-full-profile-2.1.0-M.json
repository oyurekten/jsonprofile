{
  "id": "https://github.com/HUPO-PSI/mzTab-M/tree/main/schema/profiles/mztabm-full-profile-2.1.0-M.json",
  "extends": "https://github.com/HUPO-PSI/mzTab-M/tree/main/schema/profiles/mztabm-default-profile-2.1.0-M.json",
  "version": "2.1.0-M",
  "name": "mzTab-M 2.1.0-M Full Profile",
  "description": "mzTab-M Profile with 4 required sections",
  "requirements": {
    "$": {
      "enforcement_level": "required",
      "requirements": [
        {
          "code": "FULL-0001",
          "enforcement_level": "required",
          "required_properties": [
            "metadata",
            "smallMoleculeSummary",
            "smallMoleculeFeature",
            "smallMoleculeEvidence"
          ]
        }
      ]
    },
    "$.metadata.small_molecule-quantification_unit": {
      "code": "FULL-MTD-SML_QUANTIFICATION_UNIT-0001",
      "enforcement_level": "required",
      "value_constraint": {
        "type": "cv-term",
        "allow_user_defined_terms": true
      },
      "match_is_required": true
    },
    "$.metadata.small_molecule_feature-quantification_unit": {
      "code": "FULL-MTD-SMF_QUANTIFICATION_UNIT-0001",
      "enforcement_level": "required",
      "value_constraint": {
        "type": "cv-term",
        "allow_user_defined_terms": true
      },
      "match_is_required": true
    },
    "$.smallMoleculeSummary": {
      "code": "FULL-SML-0001",
      "enforcement_level": "required",
      "value_constraint": {
        "type": "items-count",
        "min_occurs": 1
      },
      "match_is_required": true
    },
    "$.smallMoleculeFeature": {
      "code": "FULL-SMF-0001",
      "enforcement_level": "required",
      "value_constraint": {
        "type": "items-count",
        "min_occurs": 1
      },
      "match_is_required": true
    },
    "$.smallMoleculeEvidence": {
      "code": "FULL-SME-0001",
      "enforcement_level": "required",
      "value_constraint": {
        "type": "items-count",
        "min_occurs": 1
      },
      "match_is_required": true
    }
  }
}
